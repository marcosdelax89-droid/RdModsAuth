@page
@model BelgaAuthAPI.Pages.CreateUserModel
@{
    ViewData["Title"] = "Criar Usuário";
    ViewData["Page"] = "CreateUser";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-person-plus"></i> Criar Novo Usuário</h1>
    <a href="/Users" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Voltar
    </a>
</div>

<div class="card">
    <div class="card-body">
        <form id="createUserForm">
            <div class="mb-3">
                <label for="username" class="form-label">Username *</label>
                <input type="text" class="form-control" id="username" required>
            </div>
            
            <div class="mb-3">
                <label for="password" class="form-label">Senha *</label>
                <input type="password" class="form-control" id="password" required>
            </div>
            
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="subscriptionName" class="form-label">Nome da Subscription</label>
                    <input type="text" class="form-control" id="subscriptionName" value="Premium" placeholder="Premium">
                </div>
                
                <div class="col-md-6 mb-3">
                    <label for="daysValid" class="form-label">Dias de Validade</label>
                    <input type="number" class="form-control" id="daysValid" value="30" min="1">
                </div>
            </div>
            
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i> Se você preencher os campos de subscription, o usuário receberá automaticamente uma assinatura ao ser criado.
            </div>
            
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-circle"></i> Criar Usuário
            </button>
        </form>
    </div>
</div>

<div id="resultMessage" class="mt-3"></div>

@section Scripts {
<script>
    document.getElementById('createUserForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const username = document.getElementById('username').value;
        const password = document.getElementById('password').value;
        const subscriptionName = document.getElementById('subscriptionName').value;
        const daysValid = parseInt(document.getElementById('daysValid').value) || 0;
        
        const data = {
            username: username,
            password: password,
            email: null,
            subscriptionName: subscriptionName || null,
            daysValid: daysValid
        };
        
        try {
            const response = await fetch('/api/admin/user', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
            });
            
            const result = await response.json();
            const resultDiv = document.getElementById('resultMessage');
            
            if (response.ok) {
                resultDiv.innerHTML = `
                    <div class="alert alert-success">
                        <i class="bi bi-check-circle"></i> Usuário criado com sucesso! ID: ${result.userId}
                    </div>
                `;
                document.getElementById('createUserForm').reset();
                setTimeout(() => {
                    window.location.href = '/Users';
                }, 2000);
            } else {
                resultDiv.innerHTML = `
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle"></i> ${result.message || 'Erro ao criar usuário'}
                    </div>
                `;
            }
        } catch (error) {
            document.getElementById('resultMessage').innerHTML = `
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle"></i> Erro: ${error.message}
                </div>
            `;
        }
    });
</script>
}

