@page
@model BelgaAuthAPI.Pages.ResellerCreateUserModel
@{
    ViewData["Title"] = "Criar Usuário";
    ViewData["Page"] = "CreateUser";
    Layout = "_ResellerLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-person-plus"></i> Criar Novo Usuário</h1>
    <a href="/ResellerUsers" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Voltar
    </a>
</div>

<div class="card">
    <div class="card-body">
        <form id="createUserForm">
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="username" class="form-label">Username *</label>
                        <input type="text" class="form-control" id="username" required>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="password" class="form-label">Senha *</label>
                        <input type="password" class="form-control" id="password" required>
                    </div>
                </div>
            </div>
            
            <div class="row">
                <div class="col-md-12">
                    <div class="mb-3">
                        <label for="subscriptionName" class="form-label">Nome da Subscription</label>
                        <input type="text" class="form-control" id="subscriptionName" placeholder="Ex: Premium, VIP" disabled style="background: #2a2a2a !important; color: #f5f5f5 !important; border-color: rgba(255, 255, 255, 0.12) !important;">
                        <small class="form-text text-muted">Preenchido automaticamente com o nome do revendedor</small>
                    </div>
                </div>
            </div>
            
            <div class="mb-3">
                <label for="daysValid" class="form-label">Dias Válidos</label>
                <select class="form-select" id="daysValid" required>
                    <option value="">Selecione a quantidade de dias</option>
                    <option value="1">1 Dia</option>
                    <option value="5">5 Dias</option>
                    <option value="7">7 Dias</option>
                    <option value="30">30 Dias</option>
                </select>
                <small class="form-text text-muted">Quantidade de dias de validade da subscription</small>
            </div>
            
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-circle"></i> Criar Usuário
            </button>
        </form>
    </div>
</div>

<div id="resultMessage" class="mt-3"></div>

@section Scripts {
<script>
    // Preencher nome do revendedor na subscription
    async function loadResellerName() {
        try {
            const response = await fetch('/api/reseller/profile');
            if (response.ok) {
                const reseller = await response.json();
                document.getElementById('subscriptionName').value = reseller.username || reseller.name || '';
            }
        } catch (error) {
            console.error('Erro ao carregar nome do revendedor:', error);
        }
    }
    
    document.getElementById('createUserForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const username = document.getElementById('username').value;
        const password = document.getElementById('password').value;
        const subscriptionName = document.getElementById('subscriptionName').value;
        const daysValid = parseInt(document.getElementById('daysValid').value);
        
        if (!daysValid || daysValid <= 0) {
            alert('Por favor, selecione uma quantidade de dias válida');
            return;
        }
        
        const resultDiv = document.getElementById('resultMessage');
        resultDiv.innerHTML = '<div class="alert alert-info">Criando usuário...</div>';
        
        try {
            const response = await fetch('/api/reseller/user', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    username: username,
                    password: password,
                    email: null,
                    subscriptionName: subscriptionName || null,
                    daysValid: daysValid
                })
            });
            
            const result = await response.json();
            
            if (response.ok) {
                resultDiv.innerHTML = '<div class="alert alert-success">Usuário criado com sucesso!</div>';
                setTimeout(() => {
                    window.location.href = '/ResellerUsers';
                }, 1500);
            } else {
                resultDiv.innerHTML = `<div class="alert alert-danger">Erro: ${result.message || 'Erro ao criar usuário'}</div>`;
            }
        } catch (error) {
            resultDiv.innerHTML = `<div class="alert alert-danger">Erro: ${error.message}</div>`;
        }
    });
    
    // Carregar nome do revendedor ao abrir a página
    loadResellerName();
</script>
}




