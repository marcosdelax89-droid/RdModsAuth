@page "/"
@model BelgaAuthAPI.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["Page"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-speedometer2"></i> Dashboard</h1>
    <span class="text-muted">@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
</div>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card stat-card">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-people"></i> Total Usuários</h5>
                <h2 id="totalUsers">0</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-person-check"></i> Usuários Online</h5>
                <h2 id="onlineUsers">0</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-key"></i> Total Licenças</h5>
                <h2 id="totalLicenses">0</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-key-fill"></i> Licenças Disponíveis</h5>
                <h2 id="availableLicenses">0</h2>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-7">
        <div class="card" style="background: #121214 !important; border: 1px solid rgba(255, 255, 255, 0.12) !important;">
            <div class="card-header" style="background: linear-gradient(135deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.02)) !important;">
                <h5 style="color: #fff !important; font-weight: 700; margin: 0;"><i class="bi bi-graph-up-arrow text-white me-2"></i> Cadastro de Usuários (Últimos 7 Dias)</h5>
            </div>
            <div class="card-body" style="background: #121214 !important; padding: 1.5rem; min-height: 300px; display: flex; align-items: center;">
                <div style="width: 100%; height: 260px; position: relative;">
                    <canvas id="registrationsChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-5">
        <div class="card" style="background: #121214 !important; border: 1px solid rgba(255, 255, 255, 0.12) !important;">
            <div class="card-header" style="background: linear-gradient(135deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.02)) !important;">
                <h5 style="color: #fff !important; font-weight: 700; margin: 0;"><i class="bi bi-pie-chart text-white me-2"></i> Distribuição de Planos</h5>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center" style="background: #121214 !important; padding: 1.5rem; min-height: 300px;">
                <div style="width: 100%; height: 260px; position: relative; display: flex; justify-content: center; align-items: center;">
                    <canvas id="plansChart" style="max-height: 250px; max-width: 250px;"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5><i class="bi bi-clock-history"></i> Usuários Recentes</h5>
            </div>
            <div class="card-body">
                <div id="recentUsers">
                    <p class="text-muted">Carregando...</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5><i class="bi bi-activity"></i> Ações Rápidas</h5>
            </div>
            <div class="card-body">
                <a href="/CreateUser" class="btn btn-primary w-100 mb-2">
                    <i class="bi bi-person-plus"></i> Criar Novo Usuário
                </a>
                <a href="/CreateLicense" class="btn btn-primary w-100 mb-2">
                    <i class="bi bi-key-fill"></i> Gerar Nova Licença
                </a>
                <a href="/Users" class="btn btn-outline-primary w-100 mb-2">
                    <i class="bi bi-list-ul"></i> Ver Todos os Usuários
                </a>
                <a href="/Licenses" class="btn btn-outline-primary w-100">
                    <i class="bi bi-key"></i> Ver Todas as Licenças
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    let regChartInstance = null;
    let plansChartInstance = null;

    async function loadStats() {
        try {
            // Carregar estatísticas
            const statsResponse = await fetch('/api/admin/stats');
            const stats = await statsResponse.json();
            
            document.getElementById('totalUsers').textContent = stats.totalUsers || 0;
            document.getElementById('onlineUsers').textContent = stats.onlineUsers || 0;
            document.getElementById('totalLicenses').textContent = stats.totalLicenses || 0;
            document.getElementById('availableLicenses').textContent = stats.availableLicenses || 0;
            
            // Carregar todos os usuários para alimentar os gráficos
            const usersResponse = await fetch('/api/admin/users');
            const users = await usersResponse.json();
            
            const recentUsers = users.slice(0, 5);
            const usersHtml = recentUsers.length > 0 
                ? recentUsers.map(u => `
                    <div class="d-flex justify-content-between align-items-center mb-2 p-2 border-bottom">
                        <div>
                            <strong>${u.username}</strong><br>
                            <small class="text-muted">Criado em: ${new Date(u.createdDate).toLocaleDateString('pt-BR')}</small>
                        </div>
                        <span class="badge ${u.isBanned ? 'bg-danger' : 'bg-success'}">
                            ${u.isBanned ? 'Banido' : 'Ativo'}
                        </span>
                    </div>
                `).join('')
                : '<p class="text-muted">Nenhum usuário encontrado</p>';
            
            document.getElementById('recentUsers').innerHTML = usersHtml;

            // Renderizar Gráfico de Cadastro (Linha)
            renderRegistrationsChart(users);
            
            // Renderizar Gráfico de Planos (Doughnut)
            renderPlansChart(users);

        } catch (error) {
            console.error('Erro ao carregar estatísticas:', error);
        }
    }
    
    function renderRegistrationsChart(users) {
        const last7Days = Array.from({ length: 7 }, (_, i) => {
            const d = new Date();
            d.setDate(d.getDate() - i);
            return d.toISOString().split('T')[0];
        }).reverse();
        
        const registrationCounts = last7Days.map(dateStr => {
            return users.filter(u => u.createdDate.split('T')[0] === dateStr).length;
        });
        
        const dateLabels = last7Days.map(dateStr => {
            const parts = dateStr.split('-');
            return `${parts[2]}/${parts[1]}`;
        });

        const ctx = document.getElementById('registrationsChart').getContext('2d');
        
        if (regChartInstance) {
            regChartInstance.data.datasets[0].data = registrationCounts;
            regChartInstance.update();
            return;
        }

        regChartInstance = new Chart(ctx, {
            type: 'line',
            data: {
                labels: dateLabels,
                datasets: [{
                    label: 'Novos Cadastros',
                    data: registrationCounts,
                    borderColor: '#ffffff',
                    borderWidth: 3,
                    backgroundColor: 'rgba(255, 255, 255, 0.08)',
                    fill: true,
                    tension: 0.4,
                    pointBackgroundColor: '#fff',
                    pointBorderColor: '#ffffff',
                    pointRadius: 5,
                    pointHoverRadius: 7
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    x: {
                        grid: { color: 'rgba(255, 255, 255, 0.05)' },
                        ticks: { color: '#a3a3a3', font: { family: 'Outfit' } }
                    },
                    y: {
                        grid: { color: 'rgba(255, 255, 255, 0.05)' },
                        ticks: { 
                            color: '#a3a3a3', 
                            stepSize: 1, 
                            font: { family: 'Outfit' } 
                        },
                        beginAtZero: true
                    }
                }
            }
        });
    }

    function renderPlansChart(users) {
        const plans = {};
        users.forEach(u => {
            if (u.subscriptions && u.subscriptions.length > 0) {
                u.subscriptions.forEach(s => {
                    const name = s.subscriptionName || "Outros";
                    plans[name] = (plans[name] || 0) + 1;
                });
            }
        });
        
        const planNames = Object.keys(plans);
        const planCounts = Object.values(plans);

        if (planNames.length === 0) {
            planNames.push("Nenhum plano");
            planCounts.push(0);
        }

        const ctx = document.getElementById('plansChart').getContext('2d');
        
        if (plansChartInstance) {
            plansChartInstance.data.labels = planNames;
            plansChartInstance.data.datasets[0].data = planCounts;
            plansChartInstance.update();
            return;
        }

        plansChartInstance = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: planNames,
                datasets: [{
                    data: planCounts,
                    backgroundColor: [
                        '#ffffff', // Pure White
                        '#e4e4e7', // Zinc 200
                        '#a1a1aa', // Zinc 400
                        '#71717a', // Zinc 500
                        '#3f3f46', // Zinc 700
                        '#27272a'  // Zinc 800
                    ],
                    borderWidth: 1,
                    borderColor: '#121214'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'right',
                        labels: {
                            color: '#e4e4e7',
                            font: { family: 'Outfit', size: 12 }
                        }
                    }
                },
                cutout: '70%'
            }
        });
    }
    
    loadStats();
    setInterval(loadStats, 30000); // Atualiza a cada 30 segundos
</script>
}

