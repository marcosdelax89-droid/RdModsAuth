@page
@model BelgaAuthAPI.Pages.LicensesModel
@{
    ViewData["Title"] = "Gerenciar Licenças";
    ViewData["Page"] = "Licenses";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-key"></i> Gerenciar Licenças</h1>
</div>

<div class="row">
    <!-- Formulário de Criação -->
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-plus-circle"></i> Criar Nova Licença
            </div>
            <div class="card-body">
                <form id="createLicenseForm">
                    <div class="mb-3">
                        <label for="subscriptionName" class="form-label">Nome da Subscription</label>
                        <select class="form-select" id="subscriptionName" required>
                            <option value="Premium">Premium</option>
                            <option value="VIP">VIP</option>
                            <option value="VIP-Plus">VIP-Plus</option>
                            <option value="custom">Outro (Digitar abaixo)</option>
                        </select>
                    </div>
                    
                    <div class="mb-3 d-none" id="customSubscriptionDiv">
                        <label for="customSubscriptionName" class="form-label">Nome Personalizado</label>
                        <input type="text" class="form-control" id="customSubscriptionName" placeholder="Ex: VIP Gold">
                    </div>
                    
                    <div class="mb-3">
                        <label for="daysValid" class="form-label">Dias Válidos</label>
                        <input type="number" class="form-control" id="daysValid" value="30" min="1" required>
                        <small class="form-text text-muted">Validade em dias da licença após ativada</small>
                    </div>
                    
                    <div class="mb-3">
                        <label for="resellerPrefix" class="form-label">Prefixo de Revendedor (Opcional)</label>
                        <input type="text" class="form-control" id="resellerPrefix" placeholder="Ex: BELGA">
                        <small class="form-text text-muted">Prefixo inicial (BELGA-XXXX-XXXX...)</small>
                    </div>
                    
                    <div class="mb-3">
                        <label for="customKey" class="form-label">Chave Customizada (Opcional)</label>
                        <input type="text" class="form-control" id="customKey" placeholder="Ex: MINHACHAVE123">
                        <small class="form-text text-muted">Define uma licença manual específica</small>
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-magic"></i> Gerar Licença
                    </button>
                </form>
                
                <!-- Resultado de geração -->
                <div id="generationResult" class="mt-4 d-none">
                    <div class="p-3 bg-dark rounded border border-light border-opacity-10 text-center">
                        <p class="mb-1 text-muted">Licença Gerada:</p>
                        <h4 class="mb-3 text-white" id="generatedKeyDisplay" style="font-family: monospace; letter-spacing: 1px;"></h4>
                        <button class="btn btn-sm btn-outline-primary" onclick="copyGeneratedKey()">
                            <i class="bi bi-clipboard"></i> Copiar Licença
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Histórico de Licenças -->
    <div class="col-md-8 mb-4">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-clock-history"></i> Histórico de Licenças</span>
                <input type="text" class="form-control form-control-sm w-50" id="searchBox" placeholder="Buscar por chave...">
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Chave</th>
                                <th>Subscription</th>
                                <th>Dias</th>
                                <th>Status</th>
                                <th>Criado Em</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody id="licensesTable">
                            <tr>
                                <td colspan="6" class="text-center">
                                    <div class="spinner-border" role="status">
                                        <span class="visually-hidden">Carregando...</span>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let allLicenses = [];

    // Mostra/oculta input de subscription personalizado
    document.getElementById('subscriptionName').addEventListener('change', function() {
        const customDiv = document.getElementById('customSubscriptionDiv');
        if (this.value === 'custom') {
            customDiv.classList.remove('d-none');
            document.getElementById('customSubscriptionName').required = true;
        } else {
            customDiv.classList.add('d-none');
            document.getElementById('customSubscriptionName').required = false;
        }
    });

    // Carregar todas as licenças
    async function loadLicenses() {
        try {
            const response = await fetch('/api/admin/licenses');
            if (response.ok) {
                allLicenses = await response.json();
                renderLicenses(allLicenses);
            } else {
                showTableError();
            }
        } catch (error) {
            console.error('Erro ao carregar licenças:', error);
            showTableError();
        }
    }

    function renderLicenses(licenses) {
        const tbody = document.getElementById('licensesTable');
        
        if (licenses.length === 0) {
            tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted">Nenhuma licença encontrada</td></tr>';
            return;
        }

        tbody.innerHTML = licenses.map(l => {
            const created = new Date(l.createdDate).toLocaleDateString('pt-BR');
            const statusBadge = l.isUsed 
                ? `<span class="badge bg-danger">Usada (User ID: ${l.usedByUserId})</span>`
                : `<span class="badge bg-success">Disponível</span>`;
                
            return `
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <code class="text-white" style="font-size: 0.95rem;">${l.key}</code>
                            <button class="btn btn-sm p-1 text-muted hover-white" onclick="copyToClipboard('${l.key}')" title="Copiar">
                                <i class="bi bi-clipboard"></i>
                            </button>
                        </div>
                    </td>
                    <td><span class="badge bg-primary">${l.subscriptionName}</span></td>
                    <td>${l.daysValid} dias</td>
                    <td>${statusBadge}</td>
                    <td>${created}</td>
                    <td>
                        <button class="btn btn-sm btn-danger" onclick="deleteLicense(${l.id})" title="Deletar">
                            <i class="bi bi-trash"></i>
                        </button>
                    </td>
                </tr>
            `;
        }).join('');
    }

    function showTableError() {
        document.getElementById('licensesTable').innerHTML = '<tr><td colspan="6" class="text-center text-danger">Erro ao carregar licenças</td></tr>';
    }

    // Criar licença
    document.getElementById('createLicenseForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const subSelect = document.getElementById('subscriptionName').value;
        const customSub = document.getElementById('customSubscriptionName').value;
        const days = parseInt(document.getElementById('daysValid').value);
        const prefix = document.getElementById('resellerPrefix').value;
        const customKey = document.getElementById('customKey').value;
        
        const subName = subSelect === 'custom' ? customSub : subSelect;

        try {
            const response = await fetch('/api/admin/license', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    subscriptionName: subName,
                    daysValid: days,
                    customKey: customKey || null,
                    resellerPrefix: prefix || null
                })
            });

            if (response.ok) {
                const result = await response.json();
                
                // Exibir resultado
                const resultDiv = document.getElementById('generationResult');
                const displayH4 = document.getElementById('generatedKeyDisplay');
                displayH4.textContent = result.licenseKey;
                resultDiv.classList.remove('d-none');
                
                // Resetar formulário
                document.getElementById('customKey').value = '';
                
                alert('Licença gerada com sucesso!');
                loadLicenses();
            } else {
                const err = await response.json();
                alert('Erro ao gerar licença: ' + (err.message || 'Erro interno'));
            }
        } catch (error) {
            console.error('Erro:', error);
            alert('Erro de conexão ao gerar licença');
        }
    });

    // Deletar licença
    async function deleteLicense(id) {
        if (!confirm('Deseja realmente deletar esta licença?')) return;
        
        try {
            const response = await fetch(`/api/admin/licenses/${id}`, {
                method: 'DELETE'
            });

            if (response.ok) {
                alert('Licença deletada com sucesso!');
                loadLicenses();
            } else {
                alert('Erro ao deletar licença');
            }
        } catch (error) {
            console.error('Erro:', error);
            alert('Erro ao deletar licença');
        }
    }

    // Copiar
    function copyGeneratedKey() {
        const key = document.getElementById('generatedKeyDisplay').textContent;
        copyToClipboard(key);
    }

    function copyToClipboard(text) {
        navigator.clipboard.writeText(text);
        alert('Copiado para a área de transferência!');
    }

    // Busca rápida
    document.getElementById('searchBox').addEventListener('input', function() {
        const query = this.value.toLowerCase();
        const filtered = allLicenses.filter(l => l.key.toLowerCase().includes(query));
        renderLicenses(filtered);
    });

    // Inicialização
    loadLicenses();
</script>
}
