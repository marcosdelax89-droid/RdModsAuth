@page
@model BelgaAuthAPI.Pages.UsersModel
@{
    ViewData["Title"] = "Gerenciar Usuários";
    ViewData["Page"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-people"></i> Gerenciar Usuários</h1>
    <a href="/CreateUser" class="btn btn-primary">
        <i class="bi bi-person-plus"></i> Criar Novo Usuário
    </a>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive" style="overflow-x: auto !important; border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.12) !important;">
            <table class="table table-hover" style="min-width: 1300px !important; background: #1a1a1a !important; color: #f5f5f5 !important; margin-bottom: 0 !important;">
                <thead style="background: linear-gradient(135deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03)) !important; color: #f5f5f5 !important;">
                    <tr>
                        <th style="color: #f5f5f5 !important; border-color: rgba(255, 255, 255, 0.12) !important;">ID</th>
                        <th style="color: #f5f5f5 !important; border-color: rgba(255, 255, 255, 0.12) !important;">Username</th>
                        <th style="color: #f5f5f5 !important; border-color: rgba(255, 255, 255, 0.12) !important;">Senha</th>
                        <th style="color: #f5f5f5 !important; border-color: rgba(255, 255, 255, 0.12) !important;">HWID</th>
                        <th style="color: #f5f5f5 !important; border-color: rgba(255, 255, 255, 0.12) !important;">Status</th>
                        <th style="color: #f5f5f5 !important; border-color: rgba(255, 255, 255, 0.12) !important;">Subscriptions</th>
                        <th style="color: #f5f5f5 !important; border-color: rgba(255, 255, 255, 0.12) !important;">Último Login</th>
                        <th style="min-width: 260px !important; color: #f5f5f5 !important; border-color: rgba(255, 255, 255, 0.12) !important; text-align: center; white-space: nowrap !important;">Ações</th>
                    </tr>
                </thead>
                <tbody id="usersTable" style="background: #1a1a1a !important;">
                    <tr style="background: #1a1a1a !important;">
                        <td colspan="8" class="text-center" style="color: #f5f5f5 !important;">
                            <div class="spinner-border" role="status" style="color: #ffffff !important;">
                                <span class="visually-hidden">Carregando...</span>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .table tbody tr {
        background: #1a1a1a !important;
        color: #f5f5f5 !important;
        border-color: rgba(255, 255, 255, 0.12) !important;
    }
    
    .table tbody tr:hover {
        background: rgba(255, 255, 255, 0.05) !important;
        color: #f5f5f5 !important;
    }
    
    .table tbody td {
        background: transparent !important;
        color: #f5f5f5 !important;
        border-color: rgba(255, 255, 255, 0.12) !important;
    }
    
    .table tbody td strong {
        color: #f5f5f5 !important;
    }
    
    .table tbody td small {
        color: #a3a3a3 !important;
    }
</style>



@section Scripts {
<script>
    async function loadUsers() {
        try {
            const response = await fetch('/api/admin/users');
            const users = await response.json();
            
            const tbody = document.getElementById('usersTable');
            
            if (users.length === 0) {
                tbody.innerHTML = '<tr style="background: #1a1a1a !important;"><td colspan="8" class="text-center text-muted" style="color: #a3a3a3 !important;">Nenhum usuário encontrado</td></tr>';
                return;
            }
            
            tbody.innerHTML = users.map(user => {
                const lastLogin = user.lastLogin 
                    ? new Date(user.lastLogin).toLocaleString('pt-BR')
                    : 'Nunca';
                
                const subscriptions = user.subscriptions && user.subscriptions.length > 0
                    ? user.subscriptions.map(s => {
                        if (s.isPaused) {
                            return `<span class="badge bg-info me-1" style="background: linear-gradient(135deg, #ffffff, #a1a1aa) !important; border: 1px solid rgba(255, 255, 255, 0.3); color: #000000 !important; font-weight: 800;"><i class="bi bi-snow2 me-1"></i>${s.subscriptionName} (Congelado)</span>`;
                        }
                        const expiry = new Date(s.expiryDate);
                        const now = new Date();
                        const daysLeft = Math.ceil((expiry - now) / (1000 * 60 * 60 * 24));
                        if (daysLeft <= 0) {
                            return `<span class="badge bg-danger me-1" style="background: linear-gradient(135deg, #ef4444, #991b1b) !important; border: 1px solid rgba(239, 68, 68, 0.2); font-weight: 700;">Expirado</span>`;
                        }
                        return `<span class="badge bg-success me-1" style="background: linear-gradient(135deg, #22c55e, #15803d) !important; border: 1px solid rgba(34, 197, 94, 0.2); font-weight: 700;">${s.subscriptionName} (${daysLeft}d)</span>`;
                    }).join('')
                    : '<span class="text-muted">Nenhuma</span>';
                
                const isPaused = user.subscriptions && user.subscriptions.some(s => s.isPaused);
                
                return `
                    <tr style="background: #1a1a1a !important; color: #f5f5f5 !important;">
                        <td style="color: #f5f5f5 !important; border-color: rgba(255, 255, 255, 0.12) !important;">${user.id}</td>
                        <td style="color: #f5f5f5 !important; border-color: rgba(255, 255, 255, 0.12) !important;"><strong style="color: #f5f5f5 !important;">${user.username}</strong></td>
                        <td style="color: #f5f5f5 !important; border-color: rgba(255, 255, 255, 0.12) !important;"><code class="text-white">${user.passwordPlain || '—'}</code></td>
                        <td style="color: #f5f5f5 !important; border-color: rgba(255, 255, 255, 0.12) !important;"><small class="text-muted" style="color: #a3a3a3 !important;">${user.hwid ? user.hwid.substring(0, 20) + '...' : '-'}</small></td>
                        <td style="color: #f5f5f5 !important; border-color: rgba(255, 255, 255, 0.12) !important;">
                            <span class="badge ${user.isBanned ? 'bg-danger' : 'bg-success'}">
                                ${user.isBanned ? 'Banido' : 'Ativo'}
                            </span>
                        </td>
                        <td style="color: #f5f5f5 !important; border-color: rgba(255, 255, 255, 0.12) !important;">${subscriptions}</td>
                        <td style="color: #f5f5f5 !important; border-color: rgba(255, 255, 255, 0.12) !important;"><small style="color: #a3a3a3 !important;">${lastLogin}</small></td>
                        <td style="min-width: 260px !important; color: #f5f5f5 !important; border-color: rgba(255, 255, 255, 0.12) !important; text-align: center; white-space: nowrap !important;">
                            <div class="btn-group" role="group">
                                <button class="btn btn-sm" onclick="toggleFreezeUser(${user.id})" title="${isPaused ? 'Descongelar Tempo' : 'Congelar Tempo'}" style="${isPaused ? 'background: linear-gradient(135deg, #ffffff, #a1a1aa) !important; border: 1px solid rgba(255, 255, 255, 0.3) !important; color: #000000 !important; box-shadow: 0 3px 8px rgba(255, 255, 255, 0.25);' : 'background: rgba(255, 255, 255, 0.08) !important; border: 1px solid rgba(255, 255, 255, 0.2) !important; color: #ffffff !important;'} margin-right: 4px; border-radius: 4px !important; font-weight: 700;">
                                    <i class="bi bi-${isPaused ? 'play-fill' : 'snow2'}"></i>
                                </button>
                                <button class="btn btn-sm" onclick="banUser(${user.id})" ${user.isBanned ? 'disabled' : ''} title="Banir" style="background: linear-gradient(135deg, #f43f5e, #be123c) !important; border: 1px solid rgba(244, 63, 94, 0.3) !important; color: #fff !important; margin-right: 4px; border-radius: 4px !important; font-weight: 700; box-shadow: 0 3px 8px rgba(244, 63, 94, 0.2); opacity: ${user.isBanned ? '0.4' : '1'};">
                                    <i class="bi bi-ban"></i>
                                </button>
                                <button class="btn btn-sm" onclick="unbanUser(${user.id})" ${!user.isBanned ? 'disabled' : ''} title="Desbanir" style="background: linear-gradient(135deg, #10b981, #047857) !important; border: 1px solid rgba(16, 185, 129, 0.3) !important; color: #fff !important; margin-right: 4px; border-radius: 4px !important; font-weight: 700; box-shadow: 0 3px 8px rgba(16, 185, 129, 0.2); opacity: ${!user.isBanned ? '0.4' : '1'};">
                                    <i class="bi bi-check-circle"></i>
                                </button>
                                <button class="btn btn-sm" onclick="resetHWID(${user.id})" title="Resetar HWID" style="background: linear-gradient(135deg, #6366f1, #4338ca) !important; border: 1px solid rgba(99, 102, 241, 0.3) !important; color: #fff !important; margin-right: 4px; border-radius: 4px !important; font-weight: 700; box-shadow: 0 3px 8px rgba(99, 102, 241, 0.2);">
                                    <i class="bi bi-arrow-clockwise"></i>
                                </button>
                                <button class="btn btn-sm" onclick="editUser(${user.id})" title="Editar" style="background: linear-gradient(135deg, #6b7280, #374151) !important; border: 1px solid rgba(107, 114, 128, 0.3) !important; color: #fff !important; margin-right: 4px; border-radius: 4px !important; font-weight: 700; box-shadow: 0 3px 8px rgba(107, 114, 128, 0.2);">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm" onclick="deleteUser(${user.id})" title="Deletar" style="background: linear-gradient(135deg, #ef4444, #b91c1c) !important; border: 1px solid rgba(239, 68, 68, 0.3) !important; color: #fff !important; border-radius: 4px !important; font-weight: 700; box-shadow: 0 3px 8px rgba(239, 68, 68, 0.2);">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
            }).join('');
        } catch (error) {
            console.error('Erro ao carregar usuários:', error);
            document.getElementById('usersTable').innerHTML = 
                '<tr style="background: #1a1a1a !important;"><td colspan="7" class="text-center text-danger" style="color: #ffb3b3 !important;">Erro ao carregar usuários</td></tr>';
        }
    }
    
    async function banUser(userId) {
        const reason = prompt('Digite o motivo do banimento:', 'Banido pelo admin');
        if (reason === null) return; // Se cancelar, não faz nada
        
        try {
            const response = await fetch(`/api/admin/users/${userId}/ban`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ reason: reason || 'Banido pelo admin' })
            });
            
            if (response.ok) {
                alert('Usuário banido com sucesso!');
                loadUsers();
            } else {
                const result = await response.json();
                alert('Erro ao banir usuário: ' + (result.message || 'Erro desconhecido'));
            }
        } catch (error) {
            console.error('Erro:', error);
            alert('Erro ao banir usuário');
        }
    }
    
    async function unbanUser(userId) {
        if (!confirm('Tem certeza que deseja desbanir este usuário?')) return;
        
        try {
            const response = await fetch(`/api/admin/users/${userId}/unban`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            
            if (response.ok) {
                alert('Usuário desbanido com sucesso!');
                loadUsers();
            } else {
                const result = await response.json();
                alert('Erro ao desbanir usuário: ' + (result.message || 'Erro desconhecido'));
            }
        } catch (error) {
            console.error('Erro:', error);
            alert('Erro ao desbanir usuário');
        }
    }
    
    async function resetHWID(userId) {
        if (!confirm('Tem certeza que deseja resetar o HWID deste usuário?\n\nO usuário precisará fazer login novamente e o HWID será vinculado à nova máquina.')) return;
        
        try {
            const response = await fetch(`/api/admin/users/${userId}/resethwid`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            
            if (response.ok) {
                alert('HWID resetado com sucesso!');
                loadUsers();
            } else {
                const result = await response.json();
                alert('Erro ao resetar HWID: ' + (result.message || 'Erro desconhecido'));
            }
        } catch (error) {
            console.error('Erro:', error);
            alert('Erro ao resetar HWID');
        }
    }
    
    async function deleteUser(userId) {
        if (!confirm('⚠️ ATENÇÃO: Tem certeza que deseja DELETAR este usuário?\n\nEsta ação é IRREVERSÍVEL e irá:\n- Deletar o usuário permanentemente\n- Deletar todas as subscriptions\n- Deletar todas as variáveis\n- Deletar todas as sessões\n\nEsta ação NÃO pode ser desfeita!')) return;
        
        if (!confirm('Confirma a exclusão permanente deste usuário?')) return;
        
        try {
            const response = await fetch(`/api/admin/users/${userId}`, {
                method: 'DELETE'
            });
            
            if (response.ok) {
                alert('Usuário deletado com sucesso!');
                loadUsers();
            } else {
                const result = await response.json();
                alert('Erro ao deletar usuário: ' + (result.message || 'Erro desconhecido'));
            }
        } catch (error) {
            console.error('Erro:', error);
            alert('Erro ao deletar usuário');
        }
    }
    
    function editUser(userId) {
        window.location.href = `/EditUser?id=${userId}`;
    }
    
    async function toggleFreezeUser(userId) {
        if (!confirm('Tem certeza que deseja congelar/descongelar a assinatura deste usuário?')) return;
        
        try {
            const response = await fetch(`/api/admin/users/${userId}/toggle-freeze`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            
            const result = await response.json();
            if (response.ok) {
                alert(result.message);
                loadUsers();
            } else {
                alert('Erro: ' + (result.message || 'Erro desconhecido'));
            }
        } catch (error) {
            console.error('Erro:', error);
            alert('Erro ao congelar/descongelar assinatura');
        }
    }
    
    loadUsers();
</script>
}
