@page
@model BelgaAuthAPI.Pages.EditResellerModel
@{
    ViewData["Title"] = "Editar Revendedor";
    ViewData["Page"] = "Resellers";
}

<style>
    body {
        font-family: 'Outfit', sans-serif !important;
    }
    .premium-card {
        background: rgba(26, 26, 26, 0.65) !important;
        backdrop-filter: blur(12px) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        border-radius: 16px !important;
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37) !important;
        padding: 2rem;
    }
    .form-control, .form-select {
        background: rgba(20, 20, 20, 0.8) !important;
        border: 1px solid rgba(255, 255, 255, 0.12) !important;
        color: #fff !important;
        border-radius: 8px !important;
    }
    .form-control:focus, .form-select:focus {
        background: rgba(20, 20, 20, 0.9) !important;
        border-color: #ffffff !important;
        color: #fff !important;
        box-shadow: 0 0 0 0.25rem rgba(255, 255, 255, 0.2) !important;
    }
    .form-control[readonly] {
        background: rgba(10, 10, 10, 0.8) !important;
        border-color: rgba(255, 255, 255, 0.1) !important;
        color: rgba(255, 255, 255, 0.5) !important;
    }
    .form-label {
        font-weight: 500 !important;
        color: rgba(255, 255, 255, 0.85) !important;
    }
    .form-check-label {
        color: rgba(255, 255, 255, 0.85) !important;
        cursor: pointer;
    }
    .btn-primary {
        background: linear-gradient(135deg, #ffffff 0%, #a1a1aa 100%) !important;
        border: none !important;
        color: #000000 !important;
        font-weight: 800 !important;
        border-radius: 8px !important;
        padding: 0.6rem 1.5rem !important;
        transition: all 0.3s ease !important;
    }
    .btn-primary:hover {
        transform: translateY(-2px) !important;
        box-shadow: 0 4px 15px rgba(255, 255, 255, 0.25) !important;
    }
    .btn-outline-secondary {
        border: 1px solid rgba(255, 255, 255, 0.2) !important;
        color: rgba(255, 255, 255, 0.8) !important;
        border-radius: 8px !important;
        transition: all 0.3s ease !important;
    }
    .btn-outline-secondary:hover {
        background: rgba(255, 255, 255, 0.08) !important;
        color: #fff !important;
        border-color: #ffffff !important;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-pencil"></i> Editar Revendedor</h1>
    <a href="/Resellers" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Voltar
    </a>
</div>

<div class="card premium-card">
    <div class="card-body p-0">
        <form id="editResellerForm">
            <div class="mb-3">
                <label for="username" class="form-label">Username</label>
                <input type="text" class="form-control" id="username" readonly>
                <small class="form-text text-muted">Username não pode ser alterado</small>
            </div>
            
            <div class="mb-3">
                <label for="password" class="form-label">Nova Senha</label>
                <input type="password" class="form-control" id="password" placeholder="Deixe em branco para não alterar">
            </div>
            
            <div class="mb-3">
                <label for="name" class="form-label">Nome Completo</label>
                <input type="text" class="form-control" id="name">
            </div>
            
            <div class="form-check mb-3">
                <input type="checkbox" class="form-check-input" id="isActive" style="border: 1px solid rgba(255, 255, 255, 0.2); background-color: rgba(0,0,0,0.5);">
                <label for="isActive" class="form-check-label ms-1">Conta Ativa</label>
            </div>
            
            <div class="mb-3">
                <label for="notes" class="form-label">Observações</label>
                <textarea class="form-control" id="notes" rows="3"></textarea>
            </div>
            
            <button type="submit" class="btn btn-primary mt-2">
                <i class="bi bi-check-circle me-1"></i> Salvar Alterações
            </button>
        </form>
    </div>
</div>

<div id="resultMessage" class="mt-3"></div>

@section Scripts {
<script>
    const resellerId = new URLSearchParams(window.location.search).get('id');
    
    async function loadReseller() {
        try {
            const response = await fetch(`/api/admin/reseller/${resellerId}`);
            if (response.ok) {
                const reseller = await response.json();
                document.getElementById('username').value = reseller.username || '';
                document.getElementById('name').value = reseller.name || '';
                document.getElementById('isActive').checked = reseller.isActive;
                document.getElementById('notes').value = reseller.notes || '';
            }
        } catch (error) {
            console.error('Erro ao carregar revendedor:', error);
        }
    }
    
    document.getElementById('editResellerForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const password = document.getElementById('password').value;
        const name = document.getElementById('name').value;
        const isActive = document.getElementById('isActive').checked;
        const notes = document.getElementById('notes').value;
        
        const resultDiv = document.getElementById('resultMessage');
        resultDiv.innerHTML = '<div class="alert alert-info" style="background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.12); color: #fff;">Salvando alterações...</div>';
        
        try {
            const body = {
                name: name || null,
                email: null,
                isActive: isActive,
                notes: notes || null
            };
            
            if (password) {
                body.password = password;
            }
            
            const response = await fetch(`/api/admin/reseller/${resellerId}`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(body)
            });
            
            const result = await response.json();
            
            if (response.ok) {
                resultDiv.innerHTML = '<div class="alert alert-success" style="background: rgba(40, 167, 69, 0.15); border: 1px solid rgba(40, 167, 69, 0.3); color: #fff;">Revendedor atualizado com sucesso!</div>';
                setTimeout(() => {
                    window.location.href = '/Resellers';
                }, 1500);
            } else {
                resultDiv.innerHTML = `<div class="alert alert-danger" style="background: rgba(220, 53, 69, 0.15); border: 1px solid rgba(220, 53, 69, 0.3); color: #fff;">Erro: ${result.message || 'Erro ao atualizar revendedor'}</div>`;
            }
        } catch (error) {
            resultDiv.innerHTML = `<div class="alert alert-danger" style="background: rgba(220, 53, 69, 0.15); border: 1px solid rgba(220, 53, 69, 0.3); color: #fff;">Erro: ${error.message}</div>`;
        }
    });
    
    if (resellerId) {
        loadReseller();
    } else {
        window.location.href = '/Resellers';
    }
</script>
}
