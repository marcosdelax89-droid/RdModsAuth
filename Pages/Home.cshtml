@page "/Home"
@{
    Layout = null;
    ViewData["Title"] = "BelgaAuth - Sistema de Autenticação";
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>
    <!-- Hero Section -->
    <div class="hero-section">
        <div class="container fade-in">
            <h1 class="hero-title">
                <i class="bi bi-shield-lock"></i> BelgaAuth
            </h1>
            <p class="hero-subtitle">
                Sistema de autenticação completo e seguro para suas aplicações
            </p>
            <div class="cta-buttons">
                <a href="/Login" class="btn btn-hero btn-hero-primary">
                    <i class="bi bi-box-arrow-in-right"></i> Entrar
                </a>
            </div>
        </div>
    </div>

    <!-- Features Section -->
    <div class="features-section">
        <div class="container">
            <h2 class="text-center mb-5">
                <strong>Recursos do Sistema</strong>
            </h2>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="bi bi-shield-check"></i>
                        </div>
                        <h4>Segurança</h4>
                        <p class="text-muted">
                            Sistema de autenticação seguro com criptografia e validação de HWID
                        </p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="bi bi-key"></i>
                        </div>
                        <h4>Licenças</h4>
                        <p class="text-muted">
                            Gerenciamento completo de licenças e subscriptions
                        </p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="bi bi-speedometer2"></i>
                        </div>
                        <h4>Dashboard</h4>
                        <p class="text-muted">
                            Painel completo para gerenciar usuários e licenças
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="text-center text-white py-4">
        <div class="container">
            <p>&copy; 2024 BelgaAuth - Sistema de Autenticação KeyAuth</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
</body>
</html>

