@page
@model BelgaAuthAPI.Pages.EditUserModel
@{
    ViewData["Title"] = "Editar Usuário";
    ViewData["Page"] = "EditUser";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-pencil-square"></i> Editar Usuário</h1>
    <a href="/Users" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Voltar
    </a>
</div>

<div id="loading" class="text-center">
    <div class="spinner-border" role="status">
        <span class="visually-hidden">Carregando...</span>
    </div>
</div>

<div id="userInfo" style="display: none;">
    <div class="row">
        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header">
                    <h5><i class="bi bi-person"></i> Informações do Usuário</h5>
                </div>
                <div class="card-body">
                    <p><strong>ID:</strong> <span id="userId"></span></p>
                    <p><strong>Username:</strong> <span id="username"></span></p>
                    <p><strong>HWID:</strong> <span id="hwid"></span></p>
                    <p><strong>Status:</strong> 
                        <span id="status" class="badge"></span>
                    </p>
                    <p><strong>Acesso Admin:</strong> 
                        <span id="isAdmin" class="badge"></span>
                    </p>
                    <p><strong>Data de Criação:</strong> <span id="createdDate"></span></p>
                    <p><strong>Último Login:</strong> <span id="lastLogin"></span></p>
                    <p><strong>Tempo Restante para Expiração:</strong> 
                        <span id="timeLeftUntilExpiry" class="badge bg-info"></span>
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header">
                    <h5><i class="bi bi-calendar-check"></i> Adicionar Dias</h5>
                </div>
                <div class="card-body">
                    <form id="addDaysForm">
                        <div class="mb-3">
                            <label for="daysToAdd" class="form-label">Quantidade de Dias</label>
                            <input type="number" class="form-control" id="daysToAdd" min="1" value="30" required>
                        </div>
                        
                        <div class="mb-3">
                            <label for="subscriptionSelect" class="form-label">Subscription</label>
                            <select class="form-select" id="subscriptionSelect">
                                <option value="">Adicionar à primeira subscription ativa</option>
                            </select>
                            <small class="form-text text-muted">Ou deixe em branco para adicionar à primeira subscription ativa</small>
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100 mb-3">
                            <i class="bi bi-plus-circle"></i> Adicionar Dias
                        </button>
                        
                        <hr>
                        
                        <div class="mb-3">
                            <label class="form-check-label">
                                <input type="checkbox" class="form-check-input" id="toggleAdminAccess">
                                Permitir acesso ao painel admin
                            </label>
                            <small class="form-text text-muted d-block">Marque para dar acesso ao painel administrativo</small>
                        </div>
                        
                        <button type="button" class="btn btn-warning w-100" onclick="updateAdminAccess()">
                            <i class="bi bi-shield-check"></i> Atualizar Acesso Admin
                        </button>
                    </form>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h5><i class="bi bi-key"></i> Alterar Senha</h5>
                </div>
                <div class="card-body">
                    <form id="changePasswordForm">
                        <div class="mb-3">
                            <label for="newPassword" class="form-label">Nova Senha</label>
                            <input type="password" class="form-control" id="newPassword" placeholder="Digite a nova senha" required style="background: rgba(0, 0, 0, 0.2) !important; color: #fff !important; border: 1px solid rgba(255, 255, 255, 0.15) !important;">
                        </div>
                        <button type="submit" class="btn btn-primary w-100" style="background: linear-gradient(135deg, #ffffff, #a1a1aa) !important; border: 1px solid rgba(255, 255, 255, 0.3) !important; color: #000000 !important; font-weight: 800;">
                            <i class="bi bi-check-circle"></i> Atualizar Senha
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h5><i class="bi bi-list-check"></i> Subscriptions Ativas</h5>
        </div>
        <div class="card-body">
            <div id="subscriptionsList">
                <p class="text-muted">Carregando subscriptions...</p>
            </div>
        </div>
    </div>
</div>

<div id="resultMessage" class="mt-3"></div>

@section Scripts {
<script>
    const urlParams = new URLSearchParams(window.location.search);
    const userId = urlParams.get('id');

    if (!userId) {
        alert('ID do usuário não fornecido!');
        window.location.href = '/Users';
    }

    async function loadUser() {
        try {
            const response = await fetch(`/api/admin/users/${userId}`);
            const user = await response.json();
            
            // Preencher informações do usuário
            document.getElementById('userId').textContent = user.id;
            document.getElementById('username').textContent = user.username;
            document.getElementById('hwid').textContent = user.hwid ? user.hwid.substring(0, 30) + '...' : 'Não vinculado';
            
            const statusBadge = document.getElementById('status');
            if (user.isBanned) {
                statusBadge.className = 'badge bg-danger';
                statusBadge.textContent = 'Banido';
            } else {
                statusBadge.className = 'badge bg-success';
                statusBadge.textContent = 'Ativo';
            }
            
            const isAdminBadge = document.getElementById('isAdmin');
            if (user.isAdmin) {
                isAdminBadge.className = 'badge bg-primary';
                isAdminBadge.textContent = 'Sim';
            } else {
                isAdminBadge.className = 'badge bg-secondary';
                isAdminBadge.textContent = 'Não';
            }
            
            document.getElementById('toggleAdminAccess').checked = user.isAdmin || false;
            
            document.getElementById('createdDate').textContent = new Date(user.createdDate).toLocaleString('pt-BR');
            document.getElementById('lastLogin').textContent = user.lastLogin 
                ? new Date(user.lastLogin).toLocaleString('pt-BR')
                : 'Nunca';
            
            // Preencher tempo restante até expiração
            const timeLeftElement = document.getElementById('timeLeftUntilExpiry');
            if (user.timeLeftUntilExpiry) {
                if (user.timeLeftUntilExpiry === 'Expirado') {
                    timeLeftElement.className = 'badge bg-danger';
                    timeLeftElement.textContent = 'Expirado';
                } else {
                    timeLeftElement.className = 'badge bg-info';
                    timeLeftElement.textContent = user.timeLeftUntilExpiry;
                }
            } else {
                timeLeftElement.className = 'badge bg-secondary';
                timeLeftElement.textContent = 'N/A';
            }
            
            // Preencher subscriptions
            const subscriptionsList = document.getElementById('subscriptionsList');
            const subscriptionSelect = document.getElementById('subscriptionSelect');
            
            if (user.subscriptions && user.subscriptions.length > 0) {
                let subscriptionsHtml = '<div class="table-responsive"><table class="table"><thead><tr><th>Nome</th><th>Expira em</th><th>Dias Restantes</th><th>Status</th></tr></thead><tbody>';
                
                user.subscriptions.forEach(sub => {
                    const expiryDate = new Date(sub.expiryDate);
                    const now = new Date();
                    const daysLeft = Math.ceil((expiryDate - now) / (1000 * 60 * 60 * 24));
                    const isExpired = daysLeft < 0;
                    
                    subscriptionsHtml += `
                        <tr>
                            <td><strong>${sub.subscriptionName}</strong></td>
                            <td>${expiryDate.toLocaleString('pt-BR')}</td>
                            <td>${isExpired ? '<span class="text-danger">Expirada</span>' : daysLeft + ' dias'}</td>
                            <td>
                                <span class="badge ${isExpired ? 'bg-danger' : 'bg-success'}">
                                    ${isExpired ? 'Expirada' : 'Ativa'}
                                </span>
                            </td>
                        </tr>
                    `;
                    
                    // Adicionar ao select
                    const option = document.createElement('option');
                    option.value = sub.id;
                    option.textContent = `${sub.subscriptionName} (${isExpired ? 'Expirada' : daysLeft + ' dias restantes'})`;
                    subscriptionSelect.appendChild(option);
                });
                
                subscriptionsHtml += '</tbody></table></div>';
                subscriptionsList.innerHTML = subscriptionsHtml;
            } else {
                subscriptionsList.innerHTML = '<p class="text-muted">Nenhuma subscription encontrada</p>';
            }
            
            document.getElementById('loading').style.display = 'none';
            document.getElementById('userInfo').style.display = 'block';
        } catch (error) {
            console.error('Erro ao carregar usuário:', error);
            document.getElementById('loading').innerHTML = '<div class="alert alert-danger">Erro ao carregar usuário</div>';
        }
    }
    
    document.getElementById('addDaysForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const days = parseInt(document.getElementById('daysToAdd').value);
        const subscriptionId = document.getElementById('subscriptionSelect').value;
        
        const data = {
            days: days,
            subscriptionId: subscriptionId ? parseInt(subscriptionId) : null
        };
        
        try {
            const response = await fetch(`/api/admin/users/${userId}/adddays`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            
            const result = await response.json();
            const resultDiv = document.getElementById('resultMessage');
            
            if (response.ok) {
                resultDiv.innerHTML = `
                    <div class="alert alert-success">
                        <i class="bi bi-check-circle"></i> ${result.message}
                    </div>
                `;
                
                // Recarregar dados do usuário
                setTimeout(() => {
                    loadUser();
                    resultDiv.innerHTML = '';
                }, 2000);
            } else {
                resultDiv.innerHTML = `
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle"></i> ${result.message || 'Erro ao adicionar dias'}
                    </div>
                `;
            }
        } catch (error) {
            document.getElementById('resultMessage').innerHTML = `
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle"></i> Erro: ${error.message}
                </div>
            `;
        }
    });
    
    async function updateAdminAccess() {
        const isAdmin = document.getElementById('toggleAdminAccess').checked;
        const resultDiv = document.getElementById('resultMessage');
        
        resultDiv.innerHTML = '<div class="alert alert-info">Atualizando...</div>';
        
        try {
            const response = await fetch(`/api/admin/users/${userId}/admin`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ isAdmin: isAdmin })
            });
            
            const result = await response.json();
            
            if (response.ok) {
                resultDiv.innerHTML = `
                    <div class="alert alert-success">
                        <i class="bi bi-check-circle"></i> ${result.message}
                    </div>
                `;
                
                setTimeout(() => {
                    loadUser();
                    resultDiv.innerHTML = '';
                }, 2000);
            } else {
                resultDiv.innerHTML = `
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle"></i> ${result.message || 'Erro ao atualizar acesso admin'}
                    </div>
                `;
            }
        } catch (error) {
            resultDiv.innerHTML = `
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle"></i> Erro: ${error.message}
                </div>
            `;
        }
    }

    document.getElementById('changePasswordForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const newPassword = document.getElementById('newPassword').value;
        const resultDiv = document.getElementById('resultMessage');
        
        resultDiv.innerHTML = '<div class="alert alert-info">Atualizando senha...</div>';
        
        try {
            const response = await fetch(`/api/admin/users/${userId}/password`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ password: newPassword })
            });
            
            const result = await response.json();
            
            if (response.ok) {
                resultDiv.innerHTML = `
                    <div class="alert alert-success">
                        <i class="bi bi-check-circle"></i> ${result.message}
                    </div>
                `;
                document.getElementById('newPassword').value = '';
                
                setTimeout(() => {
                    resultDiv.innerHTML = '';
                }, 3000);
            } else {
                resultDiv.innerHTML = `
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle"></i> ${result.message || 'Erro ao atualizar senha'}
                    </div>
                `;
            }
        } catch (error) {
            resultDiv.innerHTML = `
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle"></i> Erro: ${error.message}
                </div>
            `;
        }
    });
    
    loadUser();
</script>
}

