@page
@model BelgaAuthAPI.Pages.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RD MODS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #0a0203;
            background-image: 
                radial-gradient(circle at 10% 20%, rgba(225, 29, 72, 0.15) 0%, transparent 40%),
                radial-gradient(circle at 90% 80%, rgba(225, 29, 72, 0.1) 0%, transparent 50%),
                radial-gradient(circle at 50% 50%, rgba(15, 2, 3, 0.98) 0%, #0a0203 100%);
            background-attachment: fixed;
            min-height: 100vh;
            color: var(--text-light);
            position: relative;
            overflow-x: hidden;
            font-family: 'Outfit', sans-serif;
        }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: 
                repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(255, 255, 255, 0.01) 2px, rgba(255, 255, 255, 0.01) 4px);
            pointer-events: none;
            z-index: 0;
        }

        .login-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            position: relative;
            z-index: 1;
        }

        .login-card {
            background: rgba(225, 29, 72, 0.15);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border-radius: 28px;
            border: 1px solid rgba(225, 29, 72, 0.25);
            box-shadow: 
                0 30px 100px rgba(0, 0, 0, 0.8),
                0 0 80px rgba(225, 29, 72, 0.25),
                inset 0 1px 0 rgba(255, 255, 255, 0.08);
            width: 100%;
            max-width: 480px;
            padding: 3.5rem 3rem;
            position: relative;
            overflow: hidden;
            animation: fadeInScale 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
        }

        .login-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: var(--primary-gradient);
            box-shadow: 0 0 20px rgba(255, 255, 255, 0.5);
        }

        .login-tabs {
            display: flex;
            background: rgba(225, 29, 72, 0.1);
            border: 1px solid rgba(225, 29, 72, 0.2);
            border-radius: 14px;
            padding: 5px;
            margin-bottom: 2.5rem;
        }

        .login-tab {
            flex: 1;
            text-align: center;
            padding: 11px 5px;
            font-size: 0.85rem;
            font-weight: 600;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
            color: var(--text-muted);
            user-select: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }

        .login-tab.active {
            background: #ffffff;
            color: #000000 !important;
            font-weight: 800;
            box-shadow: 0 4px 20px rgba(255, 255, 255, 0.2), 0 0 0 1px rgba(255,255,255,0.3);
            letter-spacing: -0.2px;
        }

        .login-tab:not(.active):hover {
            color: white;
            background: rgba(255, 255, 255, 0.06);
        }

        .float-logo {
            animation: float 4s ease-in-out infinite;
            filter: drop-shadow(0 0 20px rgba(255, 255, 255, 0.3));
            color: #ffffff;
            margin-bottom: 1.5rem;
            display: inline-block;
        }

        .login-title-text {
            font-size: 2.4rem;
            font-weight: 800;
            letter-spacing: -0.5px;
            background: var(--primary-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-shadow: 0 0 35px rgba(255, 255, 255, 0.15);
            margin-bottom: 0.5rem;
        }

        .login-subtitle-text {
            color: var(--text-muted);
            font-size: 0.95rem;
            margin-bottom: 2rem;
        }

        .form-label {
            color: var(--text-light);
            font-weight: 500;
            margin-bottom: 0.5rem;
            font-size: 0.95rem;
        }

        .form-check-label {
            color: var(--text-muted);
            font-size: 0.9rem;
            user-select: none;
        }

        .form-check-input {
            background-color: rgba(225, 29, 72, 0.1);
            border: 1px solid rgba(225, 29, 72, 0.2);
        }

        .form-check-input:checked {
            background-color: #ffffff;
            border-color: #ffffff;
            box-shadow: 0 0 10px rgba(255, 255, 255, 0.3);
        }

        .register-link {
            color: #ffffff;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
            opacity: 0.8;
        }

        .register-link:hover {
            opacity: 1;
            text-shadow: 0 0 10px rgba(255, 255, 255, 0.4);
        }

        .input-icon-wrapper {
            position: relative;
        }

        .input-icon-wrapper i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            transition: color 0.3s ease;
        }

        .input-icon-wrapper .form-control {
            padding-left: 45px;
        }

        .input-icon-wrapper .form-control:focus + i {
            color: #ffffff;
        }

        .alert-danger {
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.01)) !important;
            border-color: rgba(255, 255, 255, 0.1) !important;
            color: #ffb3b3 !important;
            border-radius: 12px;
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="login-card text-center">
            <div class="mb-2">
                <i class="bi bi-shield-lock-fill float-logo" style="font-size: 4.5rem; text-shadow: 0 0 20px rgba(255, 255, 255, 0.3);"></i>
            </div>
            
            <h1 class="login-title-text" id="titleText">RD MODS</h1>
            <p class="login-subtitle-text" id="subtitleText">Área de Clientes</p>
            
            <!-- Abas do Login Unificado -->
            <div class="login-tabs">
                <div class="login-tab active" id="tabCustomer" onclick="switchTab('customer')">
                    <i class="bi bi-person-badge"></i> Cliente
                </div>
                <div class="login-tab" id="tabReseller" onclick="switchTab('reseller')">
                    <i class="bi bi-shop"></i> Revendedor
                </div>
                <div class="login-tab" id="tabAdmin" onclick="switchTab('admin')">
                    <i class="bi bi-shield-lock"></i> Admin
                </div>
            </div>
            
            <form method="post" class="text-start">
                <!-- Tipo de Login oculto -->
                <input type="hidden" id="loginType" name="loginType" value="customer">

                <div class="mb-4">
                    <label for="username" class="form-label" id="usernameLabel">
                        Usuário / Licença
                    </label>
                    <div class="input-icon-wrapper">
                        <input type="text" class="form-control" id="username" name="username" placeholder="Digite seu usuário" required autocomplete="username">
                        <i class="bi bi-person-fill"></i>
                    </div>
                </div>
                
                <div class="mb-4">
                    <label for="password" class="form-label">
                        Senha
                    </label>
                    <div class="input-icon-wrapper">
                        <input type="password" class="form-control" id="password" name="password" placeholder="Digite sua senha" required autocomplete="current-password">
                        <i class="bi bi-lock-fill"></i>
                    </div>
                </div>
                
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="rememberMe" name="rememberMe" value="true">
                        <label class="form-check-label" for="rememberMe">Lembrar-me</label>
                    </div>
                </div>
                
                <button type="submit" class="btn btn-primary w-100 mb-4 py-3">
                    <i class="bi bi-box-arrow-in-right me-2"></i> Entrar no Painel
                </button>
                
                <div class="text-center" id="registerPrompt">
                    <span class="text-muted">Ainda não tem conta?</span>
                    <a href="/Register" class="register-link ms-1">Registre-se aqui</a>
                </div>
            </form>
            
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger mt-4 text-start" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @Model.ErrorMessage
                </div>
            }
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function switchTab(type) {
            const tabCustomer = document.getElementById('tabCustomer');
            const tabReseller = document.getElementById('tabReseller');
            const tabAdmin = document.getElementById('tabAdmin');
            const loginTypeInput = document.getElementById('loginType');
            const subtitleText = document.getElementById('subtitleText');
            const usernameLabel = document.getElementById('usernameLabel');
            const usernameInput = document.getElementById('username');
            const registerPrompt = document.getElementById('registerPrompt');
            const floatLogo = document.querySelector('.float-logo');

            // Definir valor do campo oculto do Form
            loginTypeInput.value = type;

            // Resetar classes ativas
            tabCustomer.classList.remove('active');
            tabReseller.classList.remove('active');
            tabAdmin.classList.remove('active');

            if (type === 'customer') {
                tabCustomer.classList.add('active');
                subtitleText.textContent = 'Área de Clientes';
                usernameLabel.textContent = 'Usuário / Licença';
                usernameInput.placeholder = 'Digite seu usuário';
                registerPrompt.style.display = 'block';
                
                floatLogo.className = 'bi bi-shield-lock-fill float-logo';
                floatLogo.style.color = '#ffffff';
                floatLogo.style.textShadow = '0 0 20px rgba(255, 255, 255, 0.4)';
            } else if (type === 'reseller') {
                tabReseller.classList.add('active');
                subtitleText.textContent = 'Portal de Revendedores';
                usernameLabel.textContent = 'Usuário Revendedor';
                usernameInput.placeholder = 'Digite seu login de revendedor';
                registerPrompt.style.display = 'none';
                
                floatLogo.className = 'bi bi-shop float-logo';
                floatLogo.style.color = '#a1a1aa';
                floatLogo.style.textShadow = '0 0 20px rgba(255, 255, 255, 0.2)';
            } else {
                tabAdmin.classList.add('active');
                subtitleText.textContent = 'Painel Administrativo';
                usernameLabel.textContent = 'Usuário Administrador';
                usernameInput.placeholder = 'Digite seu login de administrador';
                registerPrompt.style.display = 'none';
                
                floatLogo.className = 'bi bi-shield-lock float-logo';
                floatLogo.style.color = '#ffffff';
                floatLogo.style.textShadow = '0 0 20px rgba(255, 255, 255, 0.6)';
            }
        }

        // Recuperar abas ativas via QueryString (caso redirecionado com erro ou intencional)
        window.addEventListener('DOMContentLoaded', () => {
            const urlParams = new URLSearchParams(window.location.search);
            const type = urlParams.get('type');
            if (type === 'reseller' || type === 'admin') {
                switchTab(type);
            }
        });
    </script>
</body>
</html>
